# Copy this file to .env.local (development) or .env.production (production
# builds) and fill in values from your Supabase project settings
# (Project Settings -> API).

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional — only needed for specific features. The platform runs fine
# without any of these; the relevant feature just degrades gracefully
# (routing falls back to straight-line distance estimates, Copilot and
# billing simply aren't reachable until configured).
GOOGLE_MAPS_API_KEY=
ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
